# OpenAI 兼容 API 配置（必填）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://your-api-endpoint/v1
DEFAULT_MODEL=qwen3-coder-plus

# Tavily 搜索 API（可选，用于搜索引擎数据）
TAVILY_API_KEY=your_tavily_key_here

# 可选配置
TEMPERATURE=0.1
MAX_SEARCH_RESULTS=5
SEARCH_TIMEOUT=10
NEWS_MAX_AGE_DAYS=7
DEBUG=False
LOG_LEVEL=INFO
